# Frontend local example
VITE_API_URL=http://localhost:8080
VITE_APP_BASE_PATH=/studioflow/
VITE_APP_ENV=development
VITE_STUDIO_ID=
VITE_LOCATION_ID=

# Backend local example
STUDIOFLOW_SERVER_PORT=8080
STUDIOFLOW_DB_URL=jdbc:postgresql://localhost:5432/studioflow
STUDIOFLOW_DB_USERNAME=
STUDIOFLOW_DB_PASSWORD=
STUDIOFLOW_JWT_SECRET=change-me-before-production
STUDIOFLOW_JWT_EXPIRATION_MINUTES=720
STUDIOFLOW_PUBLIC_BOOKING_TOKEN_EXPIRATION_MINUTES=30
STUDIOFLOW_CORS_ORIGIN_1=http://localhost:5173
STUDIOFLOW_CORS_ORIGIN_2=http://localhost:5174
STUDIOFLOW_CORS_ORIGIN_3=http://localhost:5175
STUDIOFLOW_CORS_ORIGIN_4=https://ankygautam.github.io

# Backend communication placeholders
STUDIOFLOW_PUBLIC_BASE_URL=http://localhost:5175/studioflow/#
STUDIOFLOW_EMAIL_ENABLED=false
STUDIOFLOW_EMAIL_FROM_ADDRESS=noreply@studioflow.co
STUDIOFLOW_EMAIL_FROM_NAME=StudioFlow
STUDIOFLOW_MAIL_HOST=
STUDIOFLOW_MAIL_PORT=587
STUDIOFLOW_MAIL_USERNAME=
STUDIOFLOW_MAIL_PASSWORD=
STUDIOFLOW_MAIL_SMTP_AUTH=true
STUDIOFLOW_MAIL_SMTP_STARTTLS_ENABLE=true
STUDIOFLOW_SMS_ENABLED=false
STUDIOFLOW_SMS_PROVIDER=twilio
STUDIOFLOW_SMS_FROM_NUMBER=
STUDIOFLOW_SMS_ACCOUNT_SID=
STUDIOFLOW_SMS_AUTH_TOKEN=
STUDIOFLOW_REMINDERS_ENABLED=true
STUDIOFLOW_REMINDERS_CRON=0 */30 * * * *
